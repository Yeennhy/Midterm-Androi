<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Midterm"
        tools:targetApi="31">
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.accessible.AccessibleActivity"
            android:exported="false"
            android:label="@string/btn_accessible_ui" />
        <activity
            android:name=".ui.unfriendly.UnfriendlyActivity"
            android:exported="false"
            android:label="@string/btn_unfriendly_ui" />
        <activity
            android:name=".ui.unfriendly.CartUnfriendlyActivity"
            android:exported="false"
            android:label="Unfriendly Cart" />
                    <activity
            android:name=".ui.checkout.UnfriendlyCheckoutActivity"
            android:exported="false"
            android:label="Unfriendly Checkout" />
        <activity
            android:name=".ui.unfriendly.UnfriendlyVoucherActivity"
            android:exported="false"
            android:label="Unfriendly Voucher" />
        <activity
            android:name=".ui.cart.CartActivity"
            android:exported="false"
            android:label="@string/nav_cart" />
        <activity
            android:name=".ui.voucher.VoucherActivity"
            android:exported="false"
            android:label="@string/nav_voucher" />
        <activity
            android:name=".ui.checkout.CheckoutActivity"
            android:exported="false"
            android:label="@string/nav_checkout" />
        <activity
            android:name=".ui.checkout.OrderSuccessActivity"
            android:exported="false"
            android:label="Checkout Success"/>
    </application>

</manifest>
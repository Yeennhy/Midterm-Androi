<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/voucherCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_voucher_card"
    android:clipToOutline="true"
    android:orientation="horizontal">

    <FrameLayout
        android:id="@+id/badgeBox"
        android:layout_width="96dp"
        android:layout_height="match_parent"
        android:background="@color/landing_button">

        <LinearLayout
            android:id="@+id/layoutLeftBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="12dp">

            <ImageView
                android:id="@+id/ivVoucherIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_truck"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="20% OFF"
                android:textColor="@color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/hanken_grotesk_bold"
            android:text="Standard Delivery"
            android:textColor="@color/landing_description"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/hanken_grotesk_regular"
            android:text="Min. spend 100k • Cap 10k"
            android:textColor="@color/landing_title"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="bottom"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvExpiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/hanken_grotesk_regular"
                    android:letterSpacing="0.05"
                    android:text="EXPIRES 30 SEP"
                    android:textColor="@color/landing_title"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tvCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/hanken_grotesk_bold"
                    android:text="DELIVERY_20"
                    android:textColor="@color/landing_subtitle"
                    android:textSize="16sp" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_radio_outer">

                <View
                    android:id="@+id/radioDot"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_radio_dot"
                    android:visibility="invisible" />
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

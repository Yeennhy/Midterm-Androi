<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF6F0"
    android:paddingTop="16dp">

    <!-- Screen Title: "Cart" -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/hanken_grotesk_bold"
        android:text="Cart"
        android:textColor="#163328"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Progress Stepper (1 Cart -> 2 Confirmation) -->
    <LinearLayout
        android:id="@+id/layoutStepper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Step 1: Cart (Active) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStep1Icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_footer_card"
                    android:backgroundTint="#A44222"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStep1Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/hanken_grotesk_bold"
                    android:text="Cart"
                    android:textColor="#A44222"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="8dp"
                    android:background="#A44222" />
            </LinearLayout>

            <!-- Step 2: Confirmation (Inactive) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStep2Icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_footer_card"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#5A6660"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStep2Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/hanken_grotesk_regular"
                    android:text="Confirmation"
                    android:textColor="#5A6660"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="8dp"
                    android:background="#E5DEC9" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Header: Products Title & Select All Checkbox -->
    <TextView
        android:id="@+id/tvProductsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/hanken_grotesk_bold"
        android:text="Products"
        android:textColor="#163328"
        android:textSize="17sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutStepper" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbSelectAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        android:background="@null"
        android:fontFamily="@font/hanken_grotesk_regular"
        android:paddingStart="8dp"
        android:text="Select All"
        android:textColor="#4A5550"
        android:textSize="14sp"
        app:buttonTint="@color/selector_checkbox_tint"
        app:layout_constraintBottom_toBottomOf="@id/tvProductsTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvProductsTitle"
        app:useMaterialThemeColors="false" />

    <!-- Main Content Scroll Container -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar"
        app:layout_constraintTop_toBottomOf="@id/tvProductsTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp">

            <!-- Products RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCartItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_cart_product" />

            <!-- Apply Discount Code Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardApplyVoucher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F2ECE1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E5DEC9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivVoucherIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_voucher_tag"
                        app:tint="#1E2421" />

                    <TextView
                        android:id="@+id/tvApplyVoucher"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/hanken_grotesk_bold"
                        android:text="Apply discount code"
                        android:textColor="#1E2421"
                        android:textSize="15sp" />

                    <ImageView
                        android:id="@+id/ivChevron"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#5A6660" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Bar Container (Subtotal & Checkout) -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAF6F0"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSubtotalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_grotesk_regular"
                android:text="Subtotal (0 items)"
                android:textColor="#5A6660"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvSubtotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:text="0đ"
                android:textColor="#A44222"
                android:textSize="22sp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCheckout"
            android:layout_width="140dp"
            android:layout_height="52dp"
            android:backgroundTint="#A44222"
            android:enabled="false"
            android:fontFamily="@font/hanken_grotesk_bold"
            android:text="Checkout"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="26dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
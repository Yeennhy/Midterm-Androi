<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF6F0">

    <!-- Top Header Bar: Back Button & Title -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintBottom_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTitle"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/hanken_grotesk_bold"
        android:text="Confirm Order"
        android:textColor="#163328"
        android:textSize="22sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Progress Stepper (1 Cart -> 2 Confirmation) -->
    <LinearLayout
        android:id="@+id/layoutStepper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Step 1: Cart -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_footer_card"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#5A6660"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cart"
                    android:textColor="#5A6660"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="8dp"
                    android:background="#E5DEC9" />
            </LinearLayout>

            <!-- Step 2: Confirmation -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_footer_card"
                    android:backgroundTint="#A44222"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Confirmation"
                    android:textColor="#A44222"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="8dp"
                    android:background="#A44222" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar"
        app:layout_constraintTop_toBottomOf="@id/layoutStepper">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp">

            <!-- 1. Shipping Address Section -->
            <TextView
                android:id="@+id/tvAddressHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_grotesk_bold"
                android:text="Shipping Address"
                android:textColor="#163328"
                android:textSize="17sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0EBE1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvDeliverToLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:fontFamily="@font/hanken_grotesk_bold"
                            android:text="Deliver to"
                            android:textColor="#A44222"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/btnEditAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/hanken_grotesk_bold"
                            android:text="Edit"
                            android:textColor="#A44222"
                            android:textSize="14sp" />
                    </RelativeLayout>

                    <!-- View Address Display -->
                    <TextView
                        android:id="@+id/tvAddressText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/hanken_grotesk_regular"
                        android:text="53 Nguyen Du, Sai Gon Ward, HCMC"
                        android:textColor="#1E2421"
                        android:textSize="15sp" />

                    <!-- Edit Address Input Layout -->
                    <LinearLayout
                        android:id="@+id/layoutEditAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <EditText
                            android:id="@+id/etAddressInput"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_voucher_input"
                            android:fontFamily="@font/hanken_grotesk_regular"
                            android:hint="Enter shipping address"
                            android:inputType="textPostalAddress"
                            android:paddingHorizontal="16dp"
                            android:textColor="#1E2421"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveAddress"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="#A44222"
                            android:fontFamily="@font/hanken_grotesk_bold"
                            android:text="Save Address"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Order Summary Section -->
            <TextView
                android:id="@+id/tvSummaryHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/hanken_grotesk_bold"
                android:text="Order Summary"
                android:textColor="#163328"
                android:textSize="17sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0EBE1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Items Header Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:id="@+id/ivItemThumbnail"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_footer_card"
                            android:contentDescription="@null"
                            android:padding="4dp"
                            android:src="@android:drawable/ic_menu_edit" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvItemCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/hanken_grotesk_bold"
                                android:text="3 Items"
                                android:textColor="#1E2421"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvItemSubtitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:fontFamily="@font/hanken_grotesk_regular"
                                android:text="Shipping fees included"
                                android:textColor="#5A6660"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvItemTotalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk_bold"
                            android:textColor="#A44222"
                            android:textSize="17sp"
                            tools:text="232.000đ" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EBE1" />

                    <!-- Applied Voucher Row -->
                    <LinearLayout
                        android:id="@+id/layoutVoucherRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_tag"
                            app:tint="#A44222" />

                        <TextView
                            android:id="@+id/tvVoucherAppliedName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/hanken_grotesk_regular"
                            android:text="FREESHIP_NOW Applied"
                            android:textColor="#1E2421"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvVoucherDiscountAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/space_grotesk_bold"
                            android:textColor="#A44222"
                            android:textSize="14sp"
                            tools:text="-22.000đ" />
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerVoucher"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EBE1"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Subtotal & Shipping Breakdown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/hanken_grotesk_regular"
                                android:text="Subtotal"
                                android:textColor="#5A6660"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvSubtotalValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/hanken_grotesk_regular"
                                android:textColor="#1E2421"
                                android:textSize="14sp"
                                tools:text="210.000đ" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/hanken_grotesk_regular"
                                android:text="Shipping"
                                android:textColor="#5A6660"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tvShippingValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/hanken_grotesk_bold"
                                android:textColor="#2E7D32"
                                android:textSize="14sp"
                                tools:text="FREE" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Payment Method Section -->
            <TextView
                android:id="@+id/tvPaymentHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/hanken_grotesk_bold"
                android:text="Payment Method"
                android:textColor="#163328"
                android:textSize="17sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPaymentMethods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_payment_method" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FAF6F0"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hanken_grotesk_regular"
                android:text="Total Amount"
                android:textColor="#5A6660"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvTotalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/space_grotesk_bold"
                android:textColor="#A44222"
                android:textSize="22sp"
                tools:text="210.000đ" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmOrder"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:backgroundTint="#A44222"
            android:fontFamily="@font/hanken_grotesk_bold"
            android:paddingHorizontal="28dp"
            android:text="Confirm Order"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="26dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>